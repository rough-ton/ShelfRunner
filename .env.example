# ── Prowlarr ──────────────────────────────────────────────────
PROWLARR_URL=http://prowlarr:9696
PROWLARR_APIKEY=your_prowlarr_api_key_here

# ── Download directory ─────────────────────────────────────────
# HOST_DOWNLOAD_DIR: the path on your HOST machine where your download
# client (qBittorrent, NZBGet, etc.) writes completed ebook files.
# This gets bind-mounted into the container at /downloads.
HOST_DOWNLOAD_DIR=/your/host/download/path

# DOWNLOAD_DIR: the path INSIDE the container. Leave this as /downloads
# unless you change the volume mount target in docker-compose.yml.
DOWNLOAD_DIR=/downloads

# ── Kindle delivery ────────────────────────────────────────────
KINDLE_EMAIL=yourname@kindle.com

# ── SMTP (used to email the file to Kindle) ───────────────────
# Gmail example: use an App Password, not your account password.
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=you@gmail.com

# ── Tuning ────────────────────────────────────────────────────
# How long (seconds) to wait for the download before giving up
POLL_TIMEOUT=300
# How often (seconds) to check the download directory
POLL_INTERVAL=10